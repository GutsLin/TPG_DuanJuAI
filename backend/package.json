{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "worker": "tsx --env-file-if-exists=.env src/worker.ts",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx --env-file-if-exists=.env src/scripts/migrate-postgres.ts",
    "db:migrate:sqlite": "tsx --env-file-if-exists=.env src/scripts/migrate-sqlite-to-postgres.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@hono/node-server": "^1.19.11",
    "@mastra/core": "^1.17.0",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.80.10",
    "drizzle-orm": "^0.45.1",
    "fluent-ffmpeg": "^2.1.3",
    "hono": "^4.12.9",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
